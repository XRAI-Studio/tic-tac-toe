backend-node/.env
frontend/.env
frontend/build/
test_reports/
.ruff_cache/
.pytest_cache/

# Codex review scratch file
.codex-verdict.txt

# Stray scaffold git identity (don't commit)
.gitconfig

# IDE and editors
.idea/
.vscode/

# Dependencies
node_modules/
/.pnp
.pnp.js
.yarn/install-state.gz

# Testing / coverage
/coverage

# Production builds
/build
dist/

# Logs and debug files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dump.rdb

# System files
.DS_Store

# Python
__pycache__/
*.pyc
venv/
.venv/

# Deployment
.vercel

# Archive files and large assets
**/*.zip
**/*.tar.gz
**/*.tar
**/*.tgz
*.pack

# Build caches
.cache/

# Environment and credential files
.env
.env.*
*.env
credentials.json
*.pem
*.key
.credentials

# ...but DO track example env templates (no secrets). Must come AFTER the .env.* rules.
!**/.env.example
