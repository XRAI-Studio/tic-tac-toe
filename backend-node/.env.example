# Cube3 Node backend — copy to .env and fill in. Never commit the real .env.

# --- MySQL (Hostinger Business: create the DB + user in hPanel) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=cube3
DB_PASSWORD=change-me
DB_NAME=cube3

# --- Server ---
PORT=8001
NODE_ENV=production

# --- Security (REQUIRED in production; startup fails without these) ---
# Exact browser origins allowed for CORS-with-credentials (comma-separated). Most secure.
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# Optional dev-only fallback if you'd rather match by regex (ignored when the allowlist is set).
# CORS_ORIGIN_REGEX=^https://(www\.)?yourdomain\.com$
# Absolute public base URL (bare https origin, no path/trailing slash) for share/OG card links.
PUBLIC_BASE_URL=https://yourdomain.com

# --- Local dev only ---
# Set to "true" ONLY for local HTTP testing so cookies aren't forced secure+samesite=none.
# Leave unset / "false" in production.
# INSECURE_COOKIES=true
